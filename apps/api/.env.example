NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paperweave
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTH_SECRET=your-super-secret-key-at-least-32-characters-long
AUTH_EXPIRES_IN=7d
AUTH_REFRESH_IN=30d
API_URL=http://localhost:3000

# AI Provider - pick one: openai | anthropic | gemini | groq | openrouter
AI_MODEL_PROVIDER=groq
AI_MODEL_NAME=llama-3.3-70b-versatile

# API Keys (only the one matching AI_MODEL_PROVIDER is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
